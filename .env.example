# AeroIntel local backend database connection.
# Copy this file to .env or backend/.env and replace YOUR_PASSWORD with your real local PostgreSQL password.
# Do not commit real credentials.
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@127.0.0.1:5432/aerointel

# Comma-separated browser origins allowed to call the FastAPI backend.
# Add your deployed frontend URL in production, for example:
# ALLOWED_ORIGINS=https://aerointel-command-center.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend build-time API base URL.
# In production set this to your deployed backend URL.
VITE_API_BASE_URL=http://127.0.0.1:8000
